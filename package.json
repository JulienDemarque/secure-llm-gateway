{
  "name": "secure-llm-gateway",
  "version": "1.0.0",
  "description": "SecureLLM Gateway placeholder API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src/app.auth.test.ts src/app.rate-limit.test.ts src/app.prompt-injection.test.ts src/app.audit.test.ts",
    "test:watch": "vitest src/app.auth.test.ts src/app.rate-limit.test.ts src/app.prompt-injection.test.ts src/app.audit.test.ts",
    "test:integration:redis": "ENABLE_REDIS_INTEGRATION_TESTS=1 vitest run src/app.rate-limit.redis.integration.test.ts",
    "seed:api-keys": "tsx src/scripts/seed-api-keys.ts",
    "docker:up": "docker compose up -d --build",
    "docker:up:dev": "docker compose --profile dev up -d --build api-dev",
    "docker:down": "docker compose down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "litellm": "^0.12.0",
    "mongoose": "^9.6.2",
    "ollama": "^0.6.3",
    "redis": "^5.12.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
